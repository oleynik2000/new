generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Entity {
  id          String    @id @default(uuid())
  title       String
  description String?
  imageUrl    String?
  category    String    @default("other")
  contentType String    @default("review")
  zodiacSign  String?
  hidden      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    Comment[]
  reports     Report[]
  votes       Vote[]
  tags        TagOnEntity[]
  notifications Notification[]
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  entityId  String
  parentId  String?
  authorHash String?
  hidden    Boolean   @default(false)
  createdAt DateTime  @default(now())

  entity    Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  reports   Report[]
}

model Report {
  id         String   @id @default(uuid())
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  entity     Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  entityId   String?
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId  String?
}

model Vote {
  id        String   @id @default(uuid())
  entityId  String
  value     Int
  voterHash String
  createdAt DateTime @default(now())

  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, voterHash])
}

model Tag {
  id       String        @id @default(uuid())
  name     String        @unique
  entities TagOnEntity[]
}

model TagOnEntity {
  id       String @id @default(uuid())
  entityId String
  tagId    String

  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([entityId, tagId])
}

model UserActivity {
  id            String   @id @default(uuid())
  userHash      String   @unique
  points        Int      @default(0)
  streak        Int      @default(0)
  lastActive    DateTime @default(now())
  postsCount    Int      @default(0)
  commentsCount Int      @default(0)
  votesCount    Int      @default(0)
  createdAt     DateTime @default(now())

  badges        UserBadge[]
}

model Badge {
  id          String   @id @default(uuid())
  key         String   @unique
  nameUk      String
  nameEn      String
  nameRu      String
  nameEs      String
  descUk      String
  descEn      String
  descRu      String
  descEs      String
  icon        String
  threshold   Int      @default(0)
  createdAt   DateTime @default(now())

  users       UserBadge[]
}

model UserBadge {
  id         String   @id @default(uuid())
  userHash   String
  badgeId    String
  earnedAt   DateTime @default(now())

  user       UserActivity @relation(fields: [userHash], references: [userHash], onDelete: Cascade)
  badge      Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userHash, badgeId])
}

model Notification {
  id         String   @id @default(uuid())
  userHash   String
  type       String
  message    String
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  entity     Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)
}
